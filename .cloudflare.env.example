# Copy this file to .cloudflare.env, fill it in locally, then run:
#   chmod 600 .cloudflare.env
#   ./scripts/setup-submissions-cloudflare.sh
#
# Do not commit .cloudflare.env. It is ignored by git.

# Cloudflare account ID for the account that owns the Pages project.
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API token with account-scoped permissions:
# - Cloudflare Pages:Edit / Pages Write
# - D1:Edit / D1 Write
# - Workers R2 Storage:Edit / R2 Storage Write
# - Workers Scripts:Edit / Workers Scripts Write
CLOUDFLARE_API_TOKEN=

# Optional: set your own admin token for /admin-submissions.html.
# If omitted, setup-submissions-cloudflare.sh generates one and prints it once.
# SUBMISSIONS_ADMIN_TOKEN=
